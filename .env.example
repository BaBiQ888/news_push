# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-xxx

# ===== Feishu (Lark) =====
# Group bot webhook url
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
# Optional: webhook signing secret (if you enabled signature verification)
FEISHU_BOT_SECRET=

# Custom app credentials (only needed for cloud doc / bitable adapter)
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# ===== Google Cloud =====
# Path to Service Account JSON file (only needed for Google Sheets/Docs)
GOOGLE_APPLICATION_CREDENTIALS=./creds/gcp-sa.json

# ===== Runtime =====
# Path to config yaml. Defaults to ./config/pushers.config.yaml
CONFIG_PATH=./config/pushers.config.yaml
LOG_LEVEL=info
