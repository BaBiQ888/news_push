<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd template for daily news-push run.

  Install:
    1. Edit the placeholder paths below to match your machine.
    2. Copy to ~/Library/LaunchAgents/com.user.news-push.plist
    3. Load:   launchctl load ~/Library/LaunchAgents/com.user.news-push.plist
    4. Trigger now (test): launchctl start com.user.news-push
    5. View logs at the StandardOutPath / StandardErrorPath below.

  Unload:
    launchctl unload ~/Library/LaunchAgents/com.user.news-push.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.news-push</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Replace with absolute path to your node binary (run `which node`) -->
        <string>/usr/local/bin/node</string>
        <!-- Replace with absolute path to tsx -->
        <string>/Users/YOUR_USER/VsCodePro/JsWorkspace/twitter_push_msg/node_modules/.bin/tsx</string>
        <string>/Users/YOUR_USER/VsCodePro/JsWorkspace/twitter_push_msg/src/index.ts</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/YOUR_USER/VsCodePro/JsWorkspace/twitter_push_msg</string>

    <!-- Daily at 08:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Don't restart on success/failure; we run once per schedule -->
    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USER/VsCodePro/JsWorkspace/twitter_push_msg/logs/news-push.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USER/VsCodePro/JsWorkspace/twitter_push_msg/logs/news-push.err.log</string>

    <!-- Inherit a real PATH so node/tsx can resolve binaries -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>NODE_ENV</key>
        <string>production</string>
    </dict>
</dict>
</plist>
